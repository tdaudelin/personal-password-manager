{
  "name": "browser-extension-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "tags": [
      "scope:e2e"
    ],
    "targets": {
      "install-browsers": {
        "executor": "nx:run-commands",
        "options": {
          "command": "playwright install chromium"
        }
      },
      "e2e": {
        "executor": "@nx/playwright:playwright",
        "outputs": [
          "{workspaceRoot}/test-output/playwright/browser-extension-e2e",
          "{workspaceRoot}/test-output/playwright-report"
        ],
        "options": {
          "config": "apps/browser-extension-e2e/playwright.config.ts",
          "skipInstall": true
        },
        "configurations": {
          "ci": {
            "ci": true
          }
        },
        "dependsOn": [
          "install-browsers",
          {
            "target": "build",
            "projects": [
              "browser-extension"
            ]
          }
        ]
      },
      "lint": {
        "executor": "@nx/eslint:lint"
      }
    }
  }
}
